{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gedocs",
  "version": "0.1.0",
  "identifier": "br.edu.ifes.gedocs",
  "build": {
    "frontendDist": "../app/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../app run dev",
    "beforeBuildCommand": "npm --prefix ../app run build"
  },
  "app": {
    "windows": [
      {
        "title": "GeDoc IFES Toolkit",
        "width": 1100,
        "height": 750
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Consulta de documentos do GeDoc IFES por SIAPE",
    "longDescription": "Busca, filtra por SIAPE, baixa, classifica e resume documentos públicos do portal GeDoc do IFES; gera relatório e pacote ZIP.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
